{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*", //this section is basically the declaration of storage data 

  "InMemorySettings": { //no ConnectionString because i don't use a server 
    "Enabled": true
  },

  ///app.settings.json CatalogService
  {
    "Logging": {
      "LogLevel": {
        "Default": "Information",
        "Microsoft.AspNetCore": "Warning"
      }
    },
    "AllowedHosts": "*", //this section is basically the declaration of storage data

    "InMemorySettings": { //no ConnectionString because i don't use a server 
      "DatabaseName": "CatalogDb"
    }


  },
  ///app.settings-json NotificationService
  {
    "Logging": {
      "LogLevel": {
        "Default": "Information",
        "Microsoft.AspNetCore": "Warning"
      }
    },
    "AllowedHosts": "*", //this section is basically the declaration of storage data

    "InMemorySettings": { //no ConnectionString because i don't use a server 
      "DatabaseName": "OrderDb"
    }


  },

}

