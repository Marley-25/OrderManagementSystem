{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",                    /////this section is basically the declaration of storage data
  "InMemorySettings": {
    "Enabled": true
  },
  "CatalogService": {
    "InMemorySettings": {
      "DatabaseName": "CatalogDb"
    }
  },
  "NotificationService": {
    "InMemorySettings": {
      "DatabaseName": "OrderDb"
    }
  }
}
